{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "indexing",
            "type": "debugpy",
            "request": "launch",
            "program": "src/index/indexing.py",
            "console": "integratedTerminal",
            "args": [
                "--corpus",
                "data/corpus/corpus_all.json",
                "--index-dir",
                "data/index",
            ]
        },
        {
            "name": "parse pdf",
            "type": "debugpy",
            "request": "launch",
            "program": "src/ingest/parse_pdf.py",
            "args": [
                "--pdf",
                "data/pdf/GWM.pdf",
                "--output",
                "data/corpus/corpus_GWM.json",
                "--chunk-size",
                "500",
            ]
        }
    ]
}